---
import Base from "../layouts/Base.astro";
---

<Base title="404 -- Page Not Found | SynthOrg">
  <section class="min-h-[80vh] flex items-center justify-center px-6">
    <div class="max-w-lg mx-auto text-center">
      <p class="text-8xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-teal-400 mb-6">
        404
      </p>
      <h1 class="text-2xl font-semibold mb-4">Page not found</h1>
      <p class="text-gray-400 mb-10">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="px-8 py-3 bg-violet-600 hover:bg-violet-500 rounded-lg font-semibold transition-colors"
        >
          Home
        </a>
        <a
          href="/docs/"
          class="px-8 py-3 border border-white/20 hover:border-white/40 rounded-lg font-semibold transition-colors"
        >
          Documentation
        </a>
        <a
          href="/get/"
          class="px-8 py-3 border border-white/20 hover:border-white/40 rounded-lg font-semibold transition-colors"
        >
          Get Started
        </a>
      </div>
    </div>
  </section>
</Base>
